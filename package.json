        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/express-fileupload": "^1.5.1",
        "@types/ip": "^1.1.3",
        "@types/mocha": "^10.0.10",
        "@types/sanitize-html": "^2.16.1",
        "eslint": "^9.39.4",
        "globals": "^16.5.0",
        "jiti": "^2.7.0",
