        "rimraf": "^5.0.10",
        "ts-node": "^10.9.2",
        "tsx": "^4.22.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.59.3"
    },
    "dependencies": {
        "@colyseus/bun-websockets": "^0.17.13",
        "@colyseus/core": "^0.17.43",
        "@colyseus/tools": "^0.17.19",
        "@colyseus/ws-transport": "^0.17.13",
